# ============================================
# Love Ludhiana Fashion — Backend Environment
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ── Application ──────────────────────────────
APP_NAME=Love Ludhiana Fashion
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# ── URLs ─────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ── Database (PostgreSQL) ────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/love_ludhiana
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# ── JWT Authentication ───────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Cloudinary (Image Storage) ───────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Razorpay (Payments) ─────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Shiprocket (Shipping) ───────────────────
SHIPROCKET_EMAIL=your-shiprocket-email
SHIPROCKET_PASSWORD=your-shiprocket-password
SHIPROCKET_API_URL=https://apiv2.shiprocket.in/v1/external

# ── SMTP (Email) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@loveludhianafashion.com
SMTP_FROM_NAME=Love Ludhiana Fashion

# ── Sentry (Error Tracking) ─────────────────
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Logging ──────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=logs/app.log
