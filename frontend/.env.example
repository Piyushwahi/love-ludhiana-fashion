# ============================================
# Love Ludhiana Fashion — Frontend Environment
# ============================================
# Copy to .env and fill in values. Vite exposes VITE_ prefixed vars.

# ── API ──────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_API_VERSION=v1

# ── Application ──────────────────────────────
VITE_APP_NAME=Love Ludhiana Fashion
VITE_APP_DESCRIPTION=Kids Clothing Store (0-20 Years)
VITE_APP_VERSION=0.1.0

# ── Google OAuth ─────────────────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# ── Razorpay ─────────────────────────────────
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id

# ── Sentry ───────────────────────────────────
VITE_SENTRY_DSN=your-sentry-dsn

# ── Feature Flags ────────────────────────────
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CHAT=false
