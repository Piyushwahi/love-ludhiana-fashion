{
  "name": "Love Ludhiana Fashion Workspace",
  "dockerComposeFile": ["../docker/docker-compose.yml", "../docker/docker-compose.dev.yml"],
  "service": "backend",
  "workspaceFolder": "/app",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "redhat.vscode-yaml",
        "bierner.markdown-mermaid",
        "editorconfig.editorconfig"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true
      }
    }
  },

  "forwardPorts": [8000, 5173, 5432, 6379, 5050, 8081],

  "postCreateCommand": "pip install -e '.[dev]' && cd /app/../frontend && npm install",

  "remoteUser": "root"
}
