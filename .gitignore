# ============================================
# Love Ludhiana Fashion — .gitignore
# ============================================

# -------------------- Python --------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.Python
develop-eggs/
lib/
lib64/
parts/
sdist/
var/
*.manifest
*.spec
.installed.cfg

# Virtual Environments
.venv/
venv/
ENV/
env/

# pytest
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# MyPy
.mypy_cache/
dmypy.json
dmypy.txt

# Ruff
.ruff_cache/

# -------------------- Node --------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build output
frontend/dist/
frontend/build/
*.tsbuildinfo

# -------------------- Environment --------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging
!.env.example

# -------------------- Docker --------------------
docker-compose.override.yml

# -------------------- IDE --------------------
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# VS Code (keep workspace config, ignore personal)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# -------------------- OS --------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -------------------- Logs --------------------
logs/
*.log

# -------------------- Database --------------------
*.db
*.sqlite3

# -------------------- Misc --------------------
*.bak
*.tmp
*.temp
.cache/
